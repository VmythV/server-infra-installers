# Docker version. Empty means package-manager latest from configured repo.
DOCKER_VERSION="${DOCKER_VERSION:-}"

# Interaction.
ASSUME_YES="${ASSUME_YES:-0}"
NON_INTERACTIVE="${NON_INTERACTIVE:-0}"

# China mode.
CN="${CN:-0}"

# Data directories.
DOCKER_DATA_ROOT="${DOCKER_DATA_ROOT:-/var/lib/docker}"
DOCKER_EXEC_ROOT="${DOCKER_EXEC_ROOT:-/var/run/docker}"
DOCKER_CONFIG_DIR="${DOCKER_CONFIG_DIR:-/etc/docker}"
DOCKER_DOWNLOAD_DIR="${DOCKER_DOWNLOAD_DIR:-/var/lib/docker-installer/downloads}"
DOCKER_BACKUP_DIR="${DOCKER_BACKUP_DIR:-/var/lib/docker-installer/backups}"

# Docker daemon.
DOCKER_LOG_DRIVER="${DOCKER_LOG_DRIVER:-json-file}"
DOCKER_LOG_MAX_SIZE="${DOCKER_LOG_MAX_SIZE:-100m}"
DOCKER_LOG_MAX_FILE="${DOCKER_LOG_MAX_FILE:-3}"
DOCKER_LIVE_RESTORE="${DOCKER_LIVE_RESTORE:-true}"
DOCKER_IPTABLES="${DOCKER_IPTABLES:-true}"
DOCKER_REGISTRY_MIRRORS="${DOCKER_REGISTRY_MIRRORS:-}"
CN_DOCKER_REGISTRY_MIRRORS="${CN_DOCKER_REGISTRY_MIRRORS:-}"

# Package repositories.
DOCKER_APT_REPO_BASE="${DOCKER_APT_REPO_BASE:-https://download.docker.com/linux}"
DOCKER_YUM_REPO_BASE="${DOCKER_YUM_REPO_BASE:-https://download.docker.com/linux/centos/docker-ce.repo}"
CN_DOCKER_APT_REPO_BASE="${CN_DOCKER_APT_REPO_BASE:-https://mirrors.aliyun.com/docker-ce/linux}"
CN_DOCKER_YUM_REPO_BASE="${CN_DOCKER_YUM_REPO_BASE:-https://mirrors.aliyun.com/docker-ce/linux/centos/docker-ce.repo}"
